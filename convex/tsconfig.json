{
  "compilerOptions": {
    "allowJs": true,
    "strict": true,
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2023"],
    "types": ["node"],
    "paths": {
      "@/*": ["../*"]
    }
  },
  "include": ["./**/*"],
  "exclude": ["./_generated", "./**/*.test.ts", "./**/*.test.tsx"]
}
