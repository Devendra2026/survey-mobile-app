{
  "name": "survey-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "postinstall": "node ./scripts/apply-ngrok-patches.mjs",
    "predev": "node ./scripts/ensure-convex-api.mjs",
    "dev": "node ./scripts/dev-runner.mjs",
    "dev:clear": "node ./scripts/dev-runner.mjs --clear",
    "dev:tunnel": "node ./scripts/dev-runner.mjs --tunnel",
    "sync:convex": "node ./scripts/sync-convex.mjs",
    "ensure:convex-api": "node ./scripts/ensure-convex-api.mjs",
    "verify:convex-api": "node ./scripts/verify-convex-api.mjs",
    "deploy": "node ./scripts/convex-deploy.mjs",
    "convex:dev": "node ./scripts/convex-dev.mjs",
    "build:android": "expo run:android",
    "build:ios": "expo run:ios",
    "lint": "expo lint",
    "doctor": "react-doctor",
    "expo-doctor": "expo-doctor",
    "typecheck": "tsc --noEmit",
    "typecheck:convex": "tsc --noEmit -p ../sdv-monorepo-apps/packages/backend/convex/tsconfig.json",
    "check": "npm run verify:convex-api && npm run lint && npm run typecheck && npm run typecheck:convex && npm run doctor",
    "generate:logo": "node scripts/generate-logo-assets.mjs",
    "lockfile:eas": "node ./scripts/lockfile-eas.mjs",
    "verify:preview-native": "node ./scripts/verify-no-dev-client.mjs preview",
    "verify:clerk-convex": "node ./scripts/verify-clerk-convex.mjs",
    "verify:clerk-convex:prod": "node ./scripts/verify-clerk-convex.mjs --prod --target android",
    "verify:clerk-convex:web-prod": "node ./scripts/verify-clerk-convex.mjs --prod --target full",
    "verify:clerk-reachability": "node ./scripts/verify-clerk-reachability.mjs",
    "verify:gps-error-messages": "npx tsx --tsconfig tsconfig.json ./scripts/verify-gps-error-messages.ts",
    "verify:gps-validation": "npx tsx --tsconfig tsconfig.json ./scripts/verify-gps-validation.ts",
    "verify:wizard": "npx tsx --tsconfig tsconfig.json ./scripts/verify-wizard-validation.ts",
    "verify:tax-zone-validation": "npx tsx --tsconfig tsconfig.json ./scripts/verify-tax-zone-validation.ts",
    "verify:mutation-retry": "npx tsx --tsconfig tsconfig.json ./scripts/verify-mutation-retry.ts",
    "verify:photo-upload-queue": "npx tsx --tsconfig tsconfig.json ./scripts/verify-photo-upload-queue.ts",
    "verify:survey-edit-rules": "npx tsx --tsconfig tsconfig.json ./scripts/verify-survey-edit-rules.ts",
    "verify:unified-drafts": "npx tsx --tsconfig tsconfig.json ./scripts/verify-unified-drafts.ts",
    "verify:auth-flow": "npx tsx --tsconfig tsconfig.json ./scripts/verify-auth-flow.ts",
    "verify:pre-apk": "npm run verify:env-prod && npm run verify:clerk-reachability && npm run verify:wizard && npm run verify:gps-validation && npm run verify:gps-error-messages && npm run verify:draft-payload && npm run verify:survey-edit-rules && npm run verify:unified-drafts && npm run verify:auth-flow && npm run typecheck",
    "clerk:unblock-field-user": "node ./scripts/clerk-dev-field-unblock.mjs",
    "clerk:provision-field-user": "node ./scripts/clerk-dev-provision-field-user.mjs",
    "clerk:allowlist-oauth-redirect": "node ./scripts/clerk-allowlist-oauth-redirect.mjs",
    "clerk:allowlist-oauth-redirect:prod": "node ./scripts/clerk-allowlist-oauth-redirect.mjs --prod",
    "verify:env-prod": "node ./scripts/verify-env-prod.mjs",
    "env:sync:preview": "node ./scripts/verify-env-prod.mjs && node ./scripts/sync-eas-env.mjs preview",
    "env:sync:production": "node ./scripts/verify-env-prod.mjs && node ./scripts/sync-eas-env.mjs production",
    "verify:eas-preview": "node ./scripts/verify-env-prod.mjs && node ./scripts/verify-convex-api.mjs && node ./scripts/verify-eas-preview.mjs",
    "eas:build:android": "npx eas-cli build --platform android",
    "eas:build:android:preview": "npm run verify:eas-preview && npx eas-cli build --platform android --profile preview --non-interactive",
    "eas:build:android:dev": "npx eas-cli build --platform android --profile development --non-interactive",
    "eas:build:android:production": "npm run verify:eas-preview && npx eas-cli build --platform android --profile production --non-interactive",
    "eas-build-pre-install": "node ./scripts/configure-eas-autolinking.mjs && node ./scripts/ensure-convex-api.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@babel/plugin-transform-react-jsx": "^8.0.1",
    "@clerk/expo": "^3.1.10",
    "@expo/config": "~12.0.12",
    "@expo/schema-utils": "^0.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.26",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "^2.0.2",
    "convex": "^1.42.1",
    "expo": "^54.0.35",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "nativewind": "^4.2.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.6",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1"
  },
  "optionalDependencies": {
    "utf-8-validate": "6.0.6",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@expo/env": "^2.3.0",
    "@expo/ngrok": "4.1.3",
    "@types/node": "^26.1.1",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "expo-dev-client": "~6.0.21",
    "expo-docs-mcp": "^1.0.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-doctor": "^0.5.8",
    "react-refresh": "^0.18.0",
    "sharp": "^0.35.2",
    "svix": "^1.96.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "android": {
        "exclude": [
          "expo-dev-client",
          "expo-dev-launcher",
          "expo-dev-menu",
          "expo-dev-menu-interface"
        ]
      },
      "ios": {
        "exclude": [
          "expo-dev-client",
          "expo-dev-launcher",
          "expo-dev-menu",
          "expo-dev-menu-interface"
        ]
      }
    }
  }
}
